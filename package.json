    "devDependencies": {
        "@eslint/compat": "^2.0.3",
        "@eslint/js": "^9.39.2",
        "@navikt/aksel": "^8.8.0",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.1",
        "@types/lodash.memoize": "^4.1.9",
        "@types/node": "^25.5.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
