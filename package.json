        "dayjs": "^1.11.20",
        "env-var": "^7.5.0",
        "html-react-parser": "^5.2.17",
        "i18next": "^25.10.9",
        "iovalkey": "^0.3.3",
        "jose": "^4.15.5",
        "lodash.memoize": "^4.1.2",
        "msw": "^2.12.14",
        "next": "^16.2.1",
        "next-i18next": "^16.0.2",
        "node-cache": "^5.1.2",
        "openid-client": "^5.4.3",
        "pino": "^10.3.1",
        "react": "^19.2.3",
        "react-dom": "^19.2.3",
        "react-i18next": "^16.6.6",
        "swr": "^2.4.1",
        "uuid": "^13.0.0"
