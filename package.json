        "eslint-plugin-jest-dom": "^5.5.0",
        "eslint-plugin-jsx-a11y": "^6.10.2",
        "eslint-plugin-prettier": "^5.5.4",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.0.1",
        "eslint-plugin-testing-library": "^7.16.2",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "jsdom": "^28.1.0",
        "lint-staged": "^16.4.0",
